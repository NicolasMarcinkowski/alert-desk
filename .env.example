# ─── Base de données ─────────────────────────────────────────────
# Dev local : docker compose up -d (db seule)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/alert_desk"
# Prod (compose) : DATABASE_URL est composée depuis les variables ci-dessous
POSTGRES_USER=alertdesk
POSTGRES_PASSWORD=change-me
POSTGRES_DB=alert_desk

# ─── Auth.js v5 (Google OAuth) ───────────────────────────────────
# openssl rand -base64 32
AUTH_SECRET=
# URL publique de l'app (ex: https://alertdesk.mondomaine.fr) — requis derrière le reverse proxy
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Emails autorisés à se connecter, séparés par des virgules (fail-closed si vide)
ALLOWED_EMAILS=nicolas@example.com

# ─── Secrets applicatifs ─────────────────────────────────────────
# Chiffrement des tokens Flex / configs de notification — openssl rand -base64 32
APP_ENCRYPTION_KEY=
# Jeton du scheduler NAS pour /api/cron/* — openssl rand -hex 32
CRON_SECRET=
# Jeton admin pour /api/admin/* — openssl rand -hex 32
ADMIN_TOKEN=

# ─── Données de marché (M2) ──────────────────────────────────────
FINNHUB_API_KEY=

# ─── Notifications (M3, optionnel) ───────────────────────────────
TELEGRAM_BOT_TOKEN=
